@model IEnumerable<SnackTrackMvc.Models.Snack>

@{
    ViewData["Title"] = "All Snacks";
}

<div class="page-header d-flex justify-content-between align-items-center flex-wrap gap-3">
    <div>
        <h2 class="fw-bold mb-1">🍟 All Snacks</h2>
        <p class="mb-0 opacity-75">@Model.Count() snack(s) tracked on campus</p>
    </div>
    <a asp-action="Create" class="btn btn-warning fw-bold">
        <i class="fas fa-plus me-2"></i>Add New Snack
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <div class="fs-1">😢</div>
        <h4 class="text-muted">No snacks yet!</h4>
        <p class="text-muted">Be the first to add a campus snack.</p>
        <a asp-action="Create" class="btn btn-primary">Add First Snack</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var snack in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body d-flex flex-column">
                        <!-- Category badge + Rating -->
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge rounded-pill"
                                  style="background-color: #ff6b2b;">@snack.Category</span>
                            <span class="text-warning fw-bold">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span>@(i <= snack.Rating ? "★" : "☆")</span>
                                }
                            </span>
                        </div>

                        <h5 class="card-title fw-bold">@snack.Name</h5>
                        <p class="text-muted small mb-1">
                            <i class="fas fa-map-marker-alt me-1"></i>@snack.Location
                        </p>
                        <p class="fw-bold text-success mb-2">R@snack.Price.ToString("F2")</p>

                        @if (!string.IsNullOrEmpty(snack.Description))
                        {
                            <p class="text-muted small flex-grow-1">@snack.Description</p>
                        }

                        <!-- Action buttons -->
                        <div class="d-flex gap-2 mt-auto pt-2 border-top">
                            <a asp-action="Details" asp-route-id="@snack.Id"
                               class="btn btn-sm btn-outline-secondary flex-fill">
                                <i class="fas fa-eye me-1"></i>Details
                            </a>
                            <a asp-action="Edit" asp-route-id="@snack.Id"
                               class="btn btn-sm btn-outline-primary flex-fill">
                                <i class="fas fa-edit me-1"></i>Edit
                            </a>
                            <a asp-action="Delete" asp-route-id="@snack.Id"
                               class="btn btn-sm btn-outline-danger flex-fill">
                                <i class="fas fa-trash me-1"></i>Delete
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
